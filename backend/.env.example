# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Azure SQL Database
DB_HOST=your-server.database.windows.net
DB_NAME=squadbridge
DB_USER=squadbridge_admin
DB_PASSWORD=your_password_here
DB_PORT=1433

# Redis (Azure Cache for Redis)
REDIS_URL=rediss://:your_password@your-cache.redis.cache.windows.net:6380

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# Squad API (https://dashboard.squadco.com)
SQUAD_SECRET_KEY=sandbox_sk_your_key_here
SQUAD_WEBHOOK_SECRET=your_webhook_secret_here
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com

# Meta WhatsApp Business API
META_WHATSAPP_TOKEN=your_meta_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Spitch TTS/STT
SPITCH_API_KEY=sk_n8qNnT996wwTVPWxl4vLsnZSXXJk7dAUiSDIU8SC

# Africa's Talking (USSD)
AT_API_KEY=your_at_api_key_here
AT_USERNAME=sandbox

# Azure Storage (for Spitch audio files)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# Azure Key Vault (production only)
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/

# Logging
LOG_LEVEL=info
