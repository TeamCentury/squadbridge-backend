# =============================================================================
# SquadBridge Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to git. It is in .gitignore.
# Ask the team lead for credentials you don't have.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
# NODE_ENV: use "development" locally, "production" on Azure
NODE_ENV=development

# PORT: local dev port. Azure sets this automatically — do not change for prod.
PORT=3001

# FRONTEND_URL: used for CORS and notification links.
# Local: http://localhost:3000 | Production: https://squadbridge.ng (or Azure static URL)
FRONTEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# DATABASE — Azure SQL (Sweden Central)
# All teammates connect to the shared staging DB.
# Ask team lead if you need a local SQL Server instead.
# -----------------------------------------------------------------------------
DB_HOST=squadbridge-feaf.database.windows.net
DB_NAME=squadbridge
DB_USER=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_PORT=1433


# -----------------------------------------------------------------------------
# REDIS — Azure Cache for Redis (Sweden Central)
# Used for WhatsApp session state (wa:sess:{phone}) with 30-day TTL.
# Local alternative: install Redis locally and set REDIS_URL=redis://localhost:6379
# -----------------------------------------------------------------------------
REDIS_URL=REPLACE_WITH_REDIS_URL


# -----------------------------------------------------------------------------
# JWT — Authentication
# JWT_SECRET: must be the same across all instances. Never change in production
#             without rotating all active tokens.
# JWT_EXPIRES_IN: token lifetime. Format: "7d", "24h", "1h"
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d


# -----------------------------------------------------------------------------
# SQUAD API — Payment processing & virtual accounts
# Dashboard: https://dashboard.squadco.com
# SQUAD_BASE_URL: sandbox = https://sandbox-api-d.squadco.com
#                 production = https://api-d.squadco.com
# SQUAD_SECRET_KEY: from Squad dashboard → API Keys
# SQUAD_WEBHOOK_SECRET: from Squad dashboard → Webhooks → Secret
# SQUAD_MERCHANT_ID: your Squad merchant ID (shown on dashboard)
# PLATFORM_NUBAN: SquadBridge's own virtual account number (used for escrow)
# -----------------------------------------------------------------------------
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_SECRET_KEY=REPLACE_WITH_SQUAD_SECRET_KEY
SQUAD_WEBHOOK_SECRET=REPLACE_WITH_SQUAD_WEBHOOK_SECRET
SQUAD_MERCHANT_ID=REPLACE_WITH_SQUAD_MERCHANT_ID
PLATFORM_NUBAN=REPLACE_WITH_PLATFORM_NUBAN


# -----------------------------------------------------------------------------
# META — WhatsApp Business API
# Console: https://developers.facebook.com → Your App → WhatsApp
# META_WHATSAPP_TOKEN: permanent token from Meta Business Suite → System Users
# WHATSAPP_PHONE_NUMBER_ID: found in WhatsApp → API Setup
# WHATSAPP_BUSINESS_ACCOUNT_ID: your WhatsApp Business Account ID
# META_APP_SECRET: App → Settings → Basic → App Secret
# WHATSAPP_VERIFY_TOKEN: any string you choose; must match what you set in Meta webhook config
# -----------------------------------------------------------------------------
META_WHATSAPP_TOKEN=REPLACE_WITH_META_WHATSAPP_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REPLACE_WITH_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=REPLACE_WITH_WABA_ID
META_APP_SECRET=REPLACE_WITH_META_APP_SECRET
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_VERIFY_TOKEN


# -----------------------------------------------------------------------------
# VAPI — Voice AI platform
# Dashboard: https://dashboard.vapi.ai
# VAPI_WEBHOOK_SECRET: set in Vapi dashboard → Assistant → Server Secret.
#   Your webhook middleware validates incoming requests against this value.
#   Can be any strong random string — generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
VAPI_WEBHOOK_SECRET=REPLACE_WITH_VAPI_WEBHOOK_SECRET


# -----------------------------------------------------------------------------
# TWILIO — Phone / SMS (used for USSD fallback validation middleware)
# Console: https://console.twilio.com
# TWILIO_AUTH_TOKEN: Account → Auth Token
# -----------------------------------------------------------------------------
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN


# -----------------------------------------------------------------------------
# SPITCH — Speech-to-text & Text-to-speech (Nigerian languages)
# Dashboard: https://spitch.ai
# Used for WhatsApp voice note transcription (STT) and TTS voice replies.
# SPITCH_API_KEY: from Spitch dashboard → API Keys
# -----------------------------------------------------------------------------
SPITCH_API_KEY=REPLACE_WITH_SPITCH_API_KEY


# -----------------------------------------------------------------------------
# AFRICA'S TALKING — USSD gateway
# Dashboard: https://account.africastalking.com
# AT_USERNAME: "sandbox" for testing, your app username for production
# AT_API_KEY: from AT dashboard → Settings → API Key
# -----------------------------------------------------------------------------
AT_API_KEY=REPLACE_WITH_AT_API_KEY
AT_USERNAME=sandbox


# -----------------------------------------------------------------------------
# ANTHROPIC — Claude AI (WhatsApp chat, opportunity matching, P&L analysis)
# Console: https://console.anthropic.com → API Keys
# Model used: claude-opus-4-7
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY


# -----------------------------------------------------------------------------
# AZURE STORAGE — Blob storage for TTS audio files (Sweden Central)
# Portal: https://portal.azure.com → Storage Accounts → stsquadbridgefeaf
# Used to host WhatsApp voice reply audio files publicly.
# AZURE_STORAGE_CONNECTION_STRING: Portal → Storage Account → Access keys → Connection string
# -----------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=REPLACE_WITH_AZURE_STORAGE_CONNECTION_STRING


# -----------------------------------------------------------------------------
# AZURE KEY VAULT (optional — secrets rotation, not yet wired in app code)
# -----------------------------------------------------------------------------
AZURE_KEY_VAULT_URL=REPLACE_WITH_KEY_VAULT_URL


# -----------------------------------------------------------------------------
# AZURE APPLICATION INSIGHTS — Monitoring & telemetry
# Portal: https://portal.azure.com → Application Insights → squadbridge-feaf
# APPINSIGHTS_INSTRUMENTATIONKEY: Overview → Instrumentation Key
# -----------------------------------------------------------------------------
APPINSIGHTS_INSTRUMENTATIONKEY=REPLACE_WITH_APPINSIGHTS_KEY


# -----------------------------------------------------------------------------
# SYSTEM ADMIN — Built-in admin account
# ADMIN_EMAIL: login email for /api/v1/admin/login
# ADMIN_PASSWORD_HASH: bcrypt hash of the admin password (cost factor 10)
#   To generate a new hash: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@squadbridge.ng
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH


# -----------------------------------------------------------------------------
# LOGGING
# LOG_LEVEL: error | warn | info | debug
# Use "debug" locally to see SQL queries and full request logs.
# -----------------------------------------------------------------------------
LOG_LEVEL=info
